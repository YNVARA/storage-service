{
    "name": "storage-service",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "build": "bun build ./src/server.ts --target=node --outdir ./dist --minify && javascript-obfuscator dist --output dist",
        "dev": "bun --watch ./src/server.ts",
        "start": "bun ./dist/server.js",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/pg": "^8.20.0",
        "prettier": "^3.9.5"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@scalar/express-api-reference": "^0.10.11",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.6.0",
        "helmet": "^8.3.0",
        "javascript-obfuscator": "^5.5.0",
        "minio": "^8.0.7",
        "mongodb": "^7.5.0",
        "mysql2": "^3.23.1",
        "pg": "^8.22.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "zod": "^4.4.3"
    }
}
