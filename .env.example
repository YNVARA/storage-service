# APP CONFIGURATION
APP_NAME='STORAGE SERVICE'
APP_VERSION=1.0.0
NODE_ENV=development
APP_HOST=localhost
APP_PORT=4000
APP_DOMAIN=localhost

# CORS CONFIGURATION
CORS_ORIGINS=http://localhost:3000

# LOGGER CONFIGURATION
LOG_LEVEL=info

# DATABASE CONFIGURATION (Prefix-based - Recommended)
DB_MAIN_ENGINE=postgres
DB_MAIN_HOST=localhost
DB_MAIN_PORT=5432
DB_MAIN_USERNAME=postgres
DB_MAIN_PASSWORD=password
DB_MAIN_DATABASE=enterprise_db

# DATABASE CONFIGURATION (JSON - Optional)
# DATABASES='[{"name":"main","engine":"postgres","host":"localhost","port":5432,"database":"enterprise_db"}]'

# MINIO CONFIGURATION
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=mybucket
MINIO_PUBLIC_URL=http://localhost:9000/mybucket
